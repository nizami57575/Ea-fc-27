import socketio
import uvicorn
from fastapi import FastAPI
from match_engine import MatchEngine # Diğer dosyamızdan hakem motorunu çağırıyoruz

# Sunucu kurulumu ve CORS (Bağlantı İzinleri) ayarları
sio = socketio.AsyncServer(async_mode='asgi', cors_allowed_origins='*')
app = FastAPI(title="FC 27 Online Match Server")
app.mount("/", socketio.ASGIApp(sio))

# Aktif maçları ve bağlı oyuncuları takip etmek için
active_matches = {}
connected_players = {}

# Hakem ve Kuralları Yöneten Python Sınıfını Başlat
referee = MatchEngine()

@sio.event
async def connect(sid, environ):
    print(f"🎮 Bir oyuncu bağlandı! Cihaz Kimliği: {sid}")
    connected_players[sid] = {"team": "CR7_TEAM", "x": 0, "z": 0}
    
    # Bağlanan oyuncuya maçın güncel skorunu ve süresini gönder
    await sio.emit('match_status', referee.get_scoreboard(), room=sid)

@sio.event
async def player_movement(sid, data):
    # JavaScript'ten gelen Ronaldo veya Neymar'ın anlık konumunu al ve diğer oyuncuya ilet
    if sid in connected_players:
        connected_players[sid]["x"] = data.get("x", 0)
        connected_players[sid]["z"] = data.get("z", 0)
        await sio.emit('update_rival_position', {"id": sid, "pos": connected_players[sid]}, skip_sid=sid)

@sio.event
async def trigger_shoot(sid, shot_data):
    # Oyuncu şut çektiğinde topun kaleye girip girmediğini kontrol et
    # shot_data: {power: 85, angle: 45, shooter: 'Ronaldo'}
    print(f"⚽ Şut Tetiklendi! Şutör: {shot_data['shooter']}")
    
    # Hakem motoruna şutu gönder, gol olup olmadığını hesaplasın
    is_goal = referee.check_shot_trajectory(shot_data)
    
    if is_goal:
        referee.add_goal(shot_data['shooter'])
        # Tüm stadyuma GOL anonsu yap ve skoru güncelle
        await sio.emit('goal_scored', referee.get_scoreboard())
    else:
        await sio.emit('shot_missed', {"message": "Top dışarı çıktı veya kaleci kurtardı!"})

@sio.event
async def disconnect(sid):
    print(f"❌ Oyuncu bağlantıyı kesti: {sid}")
    if sid in connected_players:
        del connected_players[sid]

if __name__ == "__main__":
    # Sunucuyu yerel ağda başlatıyoruz
    uvicorn.run("main:app", host="0.0.0.0", port=8000, reload=True)

